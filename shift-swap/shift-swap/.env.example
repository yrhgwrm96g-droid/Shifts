# --- Microsoft Entra ID (Azure AD) app registration ---
AZURE_AD_CLIENT_ID=your-application-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret
# Use "common" to allow any Microsoft account, or your tenant ID to restrict to your organization
AZURE_AD_TENANT_ID=common

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-random-string
# Local dev: http://localhost:3000  |  Production: https://your-site.vercel.app
NEXTAUTH_URL=http://localhost:3000

# --- Supabase (Project Settings -> API) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
