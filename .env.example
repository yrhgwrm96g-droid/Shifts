# --- NextAuth ---
# Generate a long random string (40+ characters)
NEXTAUTH_SECRET=replace-with-random-string
# Local dev: http://localhost:3000  |  Production: https://your-app.wasmer.app
NEXTAUTH_URL=http://localhost:3000

# --- Supabase (Project Settings -> API) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Web Push (generate once with: npx web-push generate-vapid-keys) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key
